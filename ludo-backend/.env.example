# Flask backend production variables
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
FLASK_HOST=0.0.0.0
FLASK_PORT=7860
FLASK_DEBUG=false
PORT=7860
ALLOWED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com
MAX_CONTENT_LENGTH=104857600
PASSWORD_RESET_RETURN_TOKEN=false
MEDIA_STORAGE=s3
MEDIA_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# Optional SMTP settings for password reset emails
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# SENDER_EMAIL=no-reply@yourdomain.com

# Optional cloud dependencies for production
DATABASE_URL=postgresql://user:password@host:5432/chess
REDIS_URL=redis://:password@host:6379/0
S3_BUCKET=your-media-bucket
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# FCM service account path if you want push notifications
# serviceAccountKey.json should be mounted or copied into the container securely

# Environment: development | production (gates /payments/esewa/test_mark_paid)
ENV=production

# eSewa payment configuration
# Use EPAYTEST for the sandbox (https://uat.esewa.com.np/epay).
# Set this to your real merchant code in production.
ESEWA_MERCHANT_ID=your_merchant_id_here
ESEWA_SECRET=your_esewa_secret_if_required
# Public HTTPS URL exposed to eSewa. Must be reachable from the internet.
ESEWA_SUCCESS_URL=https://your-domain.com/api/payments/esewa/callback
ESEWA_FAIL_URL=https://your-domain.com/api/payments/esewa/callback?status=failed
BASE_URL=https://your-domain.com
